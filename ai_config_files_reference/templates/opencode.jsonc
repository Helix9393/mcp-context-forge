{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "autoupdate": true,
  "server": {
    "port": 4096
  },
  "mcp": {
    "local-filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/absolute/path"],
      "enabled": true
    },
    "remote-example": {
      "type": "remote",
      "url": "https://example.com/mcp",
      "enabled": false
    }
  }
}
